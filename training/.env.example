# Mealie ML System Environment Variables
# Copy this file to .env and fill in your values

# ─── CHAMELEON CLOUD OBJECT STORAGE ───────────────────────────────────────────
CHAMELEON_ACCESS_KEY=your_access_key_here
CHAMELEON_SECRET_KEY=your_secret_key_here

# ─── KAGGLE (for automatic data download) ─────────────────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ─── MLFLOW ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ─── MEALIE SERVICE ───────────────────────────────────────────────────────────
MEALIE_URL=http://localhost:9000
MEALIE_ADMIN_TOKEN=your_admin_token_here

# ─── MONITORING ───────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
GRAFANA_PASSWORD=admin

# ─── DEPLOYMENT ───────────────────────────────────────────────────────────────
DEPLOY_ENV=staging
# Options: staging, canary, production

# ─── KUBERNETES (if using k8s deployment) ─────────────────────────────────────
KUBE_CONFIG_PATH=~/.kube/config
KUBERNETES_NAMESPACE=mealie-production
