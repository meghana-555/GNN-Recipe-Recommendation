# Mealie GNN Recipe Recommender — consolidated environment variables.
# Copy to .env and fill in real values. .env is git-ignored.

# ─── Chameleon S3 / Object Storage (shared by data_pipeline + training + serving batch) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=https://chi.tacc.chameleoncloud.org:7480
S3_BUCKET_NAME=ObjStore_proj14

# Duplicate names used by the serving/batch container (same credentials)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=https://chi.tacc.chameleoncloud.org:7480
S3_BUCKET=ObjStore_proj14

# Chameleon-specific names used by training/ (same credentials again — alias)
CHAMELEON_ACCESS_KEY=
CHAMELEON_SECRET_KEY=

# ─── Kaggle (data pipeline + serving batch fallback) ───
KAGGLE_USERNAME=
KAGGLE_KEY=

# ─── Mealie (data pipeline + training) ───
MEALIE_BASE_URL=http://mealie-frontend:9000
MEALIE_URL=http://mealie-frontend:9000
MEALIE_API_TOKEN=
MEALIE_ADMIN_EMAIL=
MEALIE_ADMIN_PASSWORD=
MEALIE_ADMIN_TOKEN=

# ─── Postgres (Mealie backend) ───
POSTGRES_USER=mealie
POSTGRES_PASSWORD=mealie_password
POSTGRES_SERVER=mealie-postgres
POSTGRES_PORT=5432
POSTGRES_DB=mealie

# ─── MLflow (training registry + serving monitor integration) ───
MLFLOW_TRACKING_URI=http://mlflow:5000

# ─── Grafana ───
GRAFANA_PASSWORD=admin

# ─── Serving layer (cache, logs, monitor) ───
CACHE_BACKEND=redis
REDIS_HOST=redis
REDIS_PORT=6379
LOG_DIR=/logs

# ─── Deployment env label ───
DEPLOY_ENV=staging
